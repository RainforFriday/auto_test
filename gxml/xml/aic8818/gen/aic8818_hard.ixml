            <spirit:description> timer0 reset, active high, cleared automatically.\nWhen one, the Timer Counter is synchronously reset on the next positive edge of PCLK. </spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
