          <spirit:reset>
            <spirit:value>0x30002cc0</spirit:value>
            <spirit:mask>0xf0007fff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>rf_write_mode</spirit:name>
            <spirit:description> cache write operation mode: \n2’b00: write through\n2’b01: write back, no write allocate\n2’b10: write back, write allocate</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>rf_hprot_byp</spirit:name>
            <spirit:description> Bit [5]: \n1’b1: hprot[3] from CM4 go through cache  controller without modification\n1’b0: hprot[3] is provided by cache controller register\nBit [4]: \n1’b1: hprot[2] from CM4 go through cache controller without modification\n1’b0: hprot[2] is provided by cache controller register\nBit [3]: \n1’b1: hprot[1] from CM4 go through cache controller without modification\n1’b0: hprot[1] is provided by cache controller register\nBit [2]: \n1’b1: hprot[0] from CM4 go through cache controller without modification\n1’b0: hprot[0] is provided by cache controller register</spirit:description>
            <spirit:bitOffset>2</spirit:bitOffset>
            <spirit:bitWidth>4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>rf_hprot_bus_reg</spirit:name>
            <spirit:description> hprot control register which provide 4bit hprot for cache bus AHB </spirit:description>
            <spirit:bitOffset>6</spirit:bitOffset>
            <spirit:bitWidth>4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
