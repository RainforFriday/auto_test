              <spirit:bitOffset>28</spirit:bitOffset>
              <spirit:bitWidth>2</spirit:bitWidth>
              <spirit:access>read-write</spirit:access>
            </spirit:field>
            <spirit:field>
              <spirit:name>SRC_SIZE</spirit:name>
              <spirit:description> Source AHB Size.\n2'b00 : Byte;\n2'b01 : Half Word\n2'b10 : Word\n2'b11 : DWord. </spirit:description>
              <spirit:bitOffset>30</spirit:bitOffset>
              <spirit:bitWidth>2</spirit:bitWidth>
              <spirit:access>read-write</spirit:access>
            </spirit:field>
