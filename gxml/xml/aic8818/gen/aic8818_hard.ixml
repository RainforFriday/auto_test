          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>31</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>EFUSE_ALL0_CHECK_START</spirit:name>
            <spirit:description>write 1 to this bit will trigger all0 check to efuse, this bit is self-clear\n,read this bit will always get 0.(use PREADY)</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_IP_VER_reg</spirit:name>
          <spirit:addressOffset>0x14</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x100</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>18</spirit:bitOffset>
            <spirit:bitWidth>14</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>EFUSE_TYPE</spirit:name>
            <spirit:description>Efuse type: 00 TSMC</spirit:description>
            <spirit:bitOffset>16</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>EFUSE_IP_VER</spirit:name>
            <spirit:description>IP version, now is r1p0</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_CFG0</spirit:name>
          <spirit:addressOffset>0x18</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x1c0140</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>CLK_EFS_DIV</spirit:name>
            <spirit:description>Clk_efs divider, if this value is n, the frequency of controller will be divided by (n+1) from clk_efs.\nIn most case, this field not need to change.</spirit:description>
            <spirit:bitOffset>24</spirit:bitOffset>
            <spirit:bitWidth>8</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>EFUSE_STROBE_LOW_WIDTH</spirit:name>
            <spirit:description>This counter is used to control STROBE signal low level width in PGM mode, for TSMC efuse memory, no extra requirement for this signal, For 26Mhz efuse controller clock, by default, this width will be: 38.4*28=1075ns &gt; 1us.\nIf you want to speed up program speed, can configure the register to a smaller value.</spirit:description>
            <spirit:bitOffset>16</spirit:bitOffset>
            <spirit:bitWidth>8</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
            <spirit:bitWidth>7</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TPGM_TIME_CNT</spirit:name>
            <spirit:description>Program strobe high time. If set n, the Tpgm time will last for (n+1) clk_efuse cycle, only when PGM_EN=1 can write this field.</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>9</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_SEC_EN</spirit:name>
          <spirit:addressOffset>0x40</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>5</spirit:bitOffset>
            <spirit:bitWidth>27</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_LOCK_BIT_WR_EN</spirit:name>
            <spirit:description>If set the bit, lock bits will be written after PGM process.</spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_MARGIN_RD_ENABLE</spirit:name>
            <spirit:description>efuse margin read mode enable</spirit:description>
            <spirit:bitOffset>3</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>DOUBLE_BIT_EN_SEC</spirit:name>
            <spirit:description>efuse double bit enable</spirit:description>
            <spirit:bitOffset>2</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_AUTO_CHECK_ENABLE</spirit:name>
            <spirit:description>program read back auto-check enable</spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_VDD_EN</spirit:name>
            <spirit:description>efuse vdd enable</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_SEC_ERR_FLAG</spirit:name>
          <spirit:addressOffset>0x44</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>14</spirit:bitOffset>
            <spirit:bitWidth>18</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_ALL0_CHECK_FLAG</spirit:name>
            <spirit:description>the bit indicates all 0 check fail.</spirit:description>
            <spirit:bitOffset>13</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_ENK_ERR_FLAG</spirit:name>
            <spirit:description>the bit enk1 and enk2 is not switch correctly.</spirit:description>
            <spirit:bitOffset>12</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_MAGNUM_WR_FLAG</spirit:name>
            <spirit:description>the bit indicates write process without setting magic number.</spirit:description>
            <spirit:bitOffset>11</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_BLOCK0_RD_FLAG</spirit:name>
            <spirit:description>the bit indicates arbiter read block0 which may indicates unexpected access.</spirit:description>
            <spirit:bitOffset>10</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_VDD_ON_RD_FLAG</spirit:name>
            <spirit:description>the bit indicates read process without setting vdd_on to 1.</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_PG_EN_WR_FLAG</spirit:name>
            <spirit:description>the bit indicates write process without setting pg_en to 1.</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>reserved_1</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>6</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_WORD1_PROT_FLAG</spirit:name>
            <spirit:description>The bit indicates shadow block is protected and can not be programmed if double_bit_en is set.\nIf SW send a PGM command to memory block[i], and the controller found this memory block is protected(which means the highest bit is 1), this bit will set to 1.</spirit:description>
            <spirit:bitOffset>5</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_WORD0_PROT_FLAG</spirit:name>
            <spirit:description>The bit indicates block auto check failed after programming. If PGM_AUTO_CHK_EN is set, and controller compared the value read after PGM from the same block, and found the two value not match, this bit will set as an error flag. But if this block is protected, the PGM command in-fact not really send, so this bit will not set.</spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>reserved_2</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>2</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>shadow_block_auto_check_failed</spirit:name>
            <spirit:description>The bit indicates shadow block  auto check failed after programming if double_bit_en is set.\nIf PGM_AUTO_CHK_EN is set, and controller compared the value read after PGM from the same block, and found the two value not match, this bit will set as an error flag. But if this block is protected, the PGM command in-fact not really send, so this bit will not set.</spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>block_auto_check_failed</spirit:name>
            <spirit:description>The bit indicates block auto check failed after programming. If PGM_AUTO_CHK_EN is set, and controller compared the value read after PGM from the same block, and found the two value not match, this bit will set as an error flag. But if this block is protected, the PGM command in-fact not really send, so this bit will not set.</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_SEC_FLAG_CLR</spirit:name>
          <spirit:addressOffset>0x48</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>reserved_0</spirit:name>
            <spirit:description>RESERVED</spirit:description>
            <spirit:bitOffset>14</spirit:bitOffset>
            <spirit:bitWidth>18</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SEC_ALL0_CHECK_CLR</spirit:name>
            <spirit:description>write 1 will clear SEC_ALL0_CHECK_FLAG</spirit:description>
            <spirit:bitOffset>13</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
