            <spirit:description> Watchdog interrupt masked  status </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_LOCK</spirit:name>
          <spirit:addressOffset>0xc00</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_lock</spirit:name>
            <spirit:description> Watchdog lock control\nWrite 32'h1ACCE551 to this register to unlock  watchdog.\nWrite other value to this  register to lock watchdog\nIf reading this register, bit-0  is lock status, and other bits are reserved.\nIf watchdog is locked, all  control registers cannot be written by software. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
      </spirit:addressBlock>
      <spirit:addressBlock>
        <spirit:name>wdg1</spirit:name>
        <spirit:baseAddress>0x40104000</spirit:baseAddress>
        <spirit:range>0x1000</spirit:range>
        <spirit:width>32</spirit:width>
        <spirit:register>
          <spirit:name>WDG_LOAD_VAL</spirit:name>
          <spirit:addressOffset>0x0</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x3ffff</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_load_val</spirit:name>
            <spirit:description> watchdog  timer load value.\nIn reset mode, software should  load new value before timer decrease to 0.\nIn interrupt mode, this value  is counting start number.\nThe default value is about 8  seconds. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>32</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_CNT</spirit:name>
          <spirit:addressOffset>0x4</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0xffffffff</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_cnt</spirit:name>
            <spirit:description> watchdog counter value  </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>32</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_CTRL</spirit:name>
          <spirit:addressOffset>0x8</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x3</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_irq_en</spirit:name>
            <spirit:description> Watchdog interrupt enable bit\n0: interrupt is disabled\n1: interrupt is enabled\nFor reset mode: wdg_rst_en =1,  wdg_irq_en=0.\nFor interrupt mode: wdg_rst_en  =0, wdg_irq_en=1.\nFor combined mode: wdg_rst_en  =1, wdg_irq_en=1. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>wdg_run</spirit:name>
            <spirit:description> Watchdog counter open:\n0: counter stops.\n1: counter runs. </spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_CLR</spirit:name>
          <spirit:addressOffset>0xc</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x1</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_clr</spirit:name>
            <spirit:description> Watchdog interrupt clear\nWrite 1 to this bit to clear  interrupt\nRead this bit always get 0. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>write-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_RAW</spirit:name>
          <spirit:addressOffset>0x10</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x11</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_raw</spirit:name>
            <spirit:description> Watchdog interrupt raw status. Watch  dog reset cannot clear this raw status. Write wdg_int_clr can clear this raw  status. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>wdg_ld_busy</spirit:name>
            <spirit:description> Watchdog  load busy status\n0:  Watchdog is ready for new loading\n1: Last  loading is not completed\nSoftware  must not load new value when this bit is busy, that is, this bit should be  checked before any new loading.\nThis  bit is set after a new loading, and lasts two or three RTC clock cycles,  about 60us - 92us. </spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_MASK</spirit:name>
          <spirit:addressOffset>0x14</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x1</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_mask</spirit:name>
            <spirit:description> Watchdog interrupt masked  status </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_LOCK</spirit:name>
          <spirit:addressOffset>0xc00</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_lock</spirit:name>
            <spirit:description> Watchdog lock control\nWrite 32'h1ACCE551 to this register to unlock  watchdog.\nWrite other value to this  register to lock watchdog\nIf reading this register, bit-0  is lock status, and other bits are reserved.\nIf watchdog is locked, all  control registers cannot be written by software. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
      </spirit:addressBlock>
      <spirit:addressBlock>
        <spirit:name>spi</spirit:name>
        <spirit:baseAddress>0x40105000</spirit:baseAddress>
        <spirit:range>0x1000</spirit:range>
        <spirit:width>32</spirit:width>
        <spirit:register>
          <spirit:name>SPI_TXD</spirit:name>
          <spirit:addressOffset>0x0</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>SPI_TXD_RXD</spirit:name>
            <spirit:description> Write data to this address initiates a  character transmission through TX FIFO\nRead from this address retrieve data from  RX FIFO </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>32</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CLKD</spirit:name>
          <spirit:addressOffset>0x4</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x3</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>SPI_CLKD</spirit:name>
            <spirit:description>Specify the clock ratio between spi_sck and clk_spi\nspi_sck = clk_spi/2(SPI_CLKD + 1)</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL0</spirit:name>
          <spirit:addressOffset>0x8</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0xf02</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>NG_RX</spirit:name>
            <spirit:description> "1" enable RX data shift in at clock neg-edge </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>NG_TX</spirit:name>
            <spirit:description> "1" enable TX data shift out at clock neg-edge </spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>CHNL_LEN</spirit:name>
            <spirit:description> "0" 32 bits per word\n"1" 1 bits per word \n"31" 31 bits per word </spirit:description>
            <spirit:bitOffset>2</spirit:bitOffset>
            <spirit:bitWidth>5</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>LSB</spirit:name>
            <spirit:description> "1": enable transmit data from LSB </spirit:description>
            <spirit:bitOffset>7</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SPI_CSN_PRE</spirit:name>
            <spirit:description> "1": cs is invalid \n"0": cs is valid</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>Reserved</spirit:name>
            <spirit:description> Reserved </spirit:description>
            <spirit:bitOffset>12</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SCK_REV</spirit:name>
            <spirit:description> SCK inverse enable </spirit:description>
            <spirit:bitOffset>13</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SYNC_MD</spirit:name>
            <spirit:description> "1" : sync mode </spirit:description>
            <spirit:bitOffset>14</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SYNC_POL</spirit:name>
            <spirit:description> Sync polarity, positive or negative pulse for SPI or 3-wire mode, read command polarity </spirit:description>
            <spirit:bitOffset>15</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL1</spirit:name>
          <spirit:addressOffset>0xc</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x3fff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>S3W_POS</spirit:name>
            <spirit:description> 3-wire mode, w/r control position or the sync pulse position</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>5</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>S3W_MD</spirit:name>
            <spirit:description> "1" enable 3-wire mode</spirit:description>
            <spirit:bitOffset>5</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>CS_H_MD</spirit:name>
            <spirit:description> 3-wire melody timing 1, csn high mode enable</spirit:description>
            <spirit:bitOffset>6</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>S8_MD</spirit:name>
            <spirit:description> enable S8 mode</spirit:description>
            <spirit:bitOffset>7</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SYN_CSN_SEL</spirit:name>
            <spirit:description> S8 CD or SYNC signal maps to csn number\n0x1 selects csn0 as cd signal\n0x2 selects csn1 as cd signal\nin SPI_HS it must be 0x0</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RTX_MD</spirit:name>
            <spirit:description> "0x00":idle mode\n"0x01":receive mode\n"0x10":transmit mode\n"0x11":transmit and receive</spirit:description>
            <spirit:bitOffset>12</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL2</spirit:name>
          <spirit:addressOffset>0x10</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x7ff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>S3W_RD_START</spirit:name>
            <spirit:description> Read date start bit, used for 3-wire mode and 3-wire 9bit RW mode</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>5</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>IS_SLVD</spirit:name>
            <spirit:description> "1" slave,only support microplus mode\n"0" master</spirit:description>
            <spirit:bitOffset>5</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>DMA_EN</spirit:name>
            <spirit:description> "1" : enable DMA </spirit:description>
            <spirit:bitOffset>6</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RX_ONLY_HLD</spirit:name>
            <spirit:description> "0" : working on only receive mode, when rxf_realfull is high, SPI will be held until rxf realfull is low </spirit:description>
            <spirit:bitOffset>7</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RX_DMA_SEL</spirit:name>
            <spirit:description> "0" : rx_dma_req keep high until receiving the rx_dma_ack\n"1" : rx_dma_req is high when rx full is high</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TX_DMA_SEL</spirit:name>
            <spirit:description> "0" : tx_dma_req keep high until receiving the tx_dma_ack\n"1" : tx_dma_req is high when tx full is high</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>DMA_REQ_SEL</spirit:name>
            <spirit:description> "1" enable 3-wire mode</spirit:description>
            <spirit:bitOffset>10</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL3</spirit:name>
          <spirit:addressOffset>0x14</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x1010</spirit:value>
            <spirit:mask>0x1f1f</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>RXF_FULL_THLD</spirit:name>
            <spirit:description> Receive data empty threshold </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>5</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RXF_EMPTY_THLD</spirit:name>
            <spirit:description> Receive data full threshold </spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>5</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL4</spirit:name>
          <spirit:addressOffset>0x18</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>BLOCK_NUM</spirit:name>
            <spirit:description> Number of data words ready to receive in "receive only" mode.\nOnly used for master mode</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>9</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>IS_RX_ONLY</spirit:name>
            <spirit:description> "1":receive data only.The bits should be written at last.\nOnly used for master mode</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SYNC_HALF</spirit:name>
            <spirit:description> Sync half,sync width is half spi_sck cycle </spirit:description>
            <spirit:bitOffset>10</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SYNC_CLKMASK</spirit:name>
            <spirit:description> "1" Mask out the first clock pulse in SPI mode </spirit:description>
            <spirit:bitOffset>11</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>PHS_DLY</spirit:name>
            <spirit:description> Phase delay. Relate to fast mode\nWhen in normal mode,this bit is not used. Only used for slave mode </spirit:description>
            <spirit:bitOffset>12</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>IS_FST</spirit:name>
            <spirit:description> "0": normal mode\n"1": fast mode </spirit:description>
            <spirit:bitOffset>14</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RX_ONLY_DO</spirit:name>
            <spirit:description> "0": SPI send all 0 to slave\n"1": SPI send all 1 to slave </spirit:description>
            <spirit:bitOffset>15</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_CTL5</spirit:name>
          <spirit:addressOffset>0x1c</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>ITVL_NUM</spirit:name>
            <spirit:description>For master, transmit data interval, programmabl n from 0 to 65535, delay is (4*n+3) clock cycle\nFor slave, max receive data interval. If slave has not sampled data,in the interval (4*n+3) spi_clk,slave will stop the receive process and send timeout interrupt </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SPI_INT_EN</spirit:name>
          <spirit:addressOffset>0x20</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x3f6</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>RXF_EMPTY_INT_EN</spirit:name>
            <spirit:description> Rx_fifo_empty interrupt enable </spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TXF_FUL_INT_EN</spirit:name>
            <spirit:description> Tx_fifo_full interrupt enable </spirit:description>
            <spirit:bitOffset>2</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RX_OVF_INT_EN</spirit:name>
            <spirit:description> Rx_overrun_reg interrupt enable </spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TIME_OUT_INT_EN</spirit:name>
            <spirit:description> Slave mode timeout interrupt enable </spirit:description>
            <spirit:bitOffset>5</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RXF_FULL_INT_EN</spirit:name>
            <spirit:description> Rx_fifo_full interrupt enable</spirit:description>
            <spirit:bitOffset>6</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TXF_EMPTY_INT_EN</spirit:name>
            <spirit:description> Tx_fifo_empty interrupt enable</spirit:description>
            <spirit:bitOffset>7</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>TXF_END_INT_EN</spirit:name>
            <spirit:description> Tx end interrupt enable</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>RXF_END_INT_EN</spirit:name>
            <spirit:description> Rx end interrupt enable</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
