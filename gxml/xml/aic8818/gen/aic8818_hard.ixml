            <spirit:bitOffset>28</spirit:bitOffset>
            <spirit:bitWidth>2</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>rf_cmd_exec_mode</spirit:name>
            <spirit:description> 0: (recommended) software can run in cacheable region during software command processing\n1: software cannot run in cacheable region during software command processing</spirit:description>
            <spirit:bitOffset>30</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>rf_debug_en</spirit:name>
            <spirit:description> cache debug mode enable: \n0: normal mode\n1: debug mode\nThis bit MUST always be cleared during cache operating  </spirit:description>
            <spirit:bitOffset>31</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
