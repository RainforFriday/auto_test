            <spirit:name>rf_hprot_cache_reg</spirit:name>
            <spirit:description> hprot control register which provide 4bit hprot for cache ctrl AHB  </spirit:description>
            <spirit:bitOffset>10</spirit:bitOffset>
            <spirit:bitWidth>4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>ahb_ram_en</spirit:name>
            <spirit:description> Cache Data Ram Can be Write/Read Throught rf AHB Bus </spirit:description>
            <spirit:bitOffset>14</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>rf_cache_size_sel</spirit:name>
