            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EFUSE_MODE_CTRL</spirit:name>
