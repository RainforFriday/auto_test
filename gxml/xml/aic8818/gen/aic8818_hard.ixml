            <spirit:field>
              <spirit:name>CHN_PAUSE</spirit:name>
              <spirit:description> Channel Pause Enable.\n0 : Channel in active mode.\n1 : Channel pause.\nActive high, only pause the channel. If the  CHN_PAUSE asserted when the channel is busy, it should be paused after the  current fragment finished. </spirit:description>
              <spirit:bitOffset>0</spirit:bitOffset>
              <spirit:bitWidth>1</spirit:bitWidth>
              <spirit:access>read-write</spirit:access>
