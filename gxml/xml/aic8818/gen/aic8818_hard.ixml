      <spirit:addressBlock>
        <spirit:name>wdg4</spirit:name>
        <spirit:baseAddress>0x70001400</spirit:baseAddress>
        <spirit:range>0x1000</spirit:range>
        <spirit:width>32</spirit:width>
        <spirit:register>
          <spirit:name>WDG_LOAD_VAL</spirit:name>
          <spirit:addressOffset>0x0</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x3ffff</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_load_val</spirit:name>
            <spirit:description> watchdog  timer load value.\nIn reset mode, software should  load new value before timer decrease to 0.\nIn interrupt mode, this value  is counting start number.\nThe default value is about 8  seconds. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>32</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_CNT</spirit:name>
          <spirit:addressOffset>0x4</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0xffffffff</spirit:value>
            <spirit:mask>0xffffffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_cnt</spirit:name>
            <spirit:description> watchdog counter value  </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>32</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_CTRL</spirit:name>
          <spirit:addressOffset>0x8</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x3</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_irq_en</spirit:name>
            <spirit:description> Watchdog interrupt enable bit\n0: interrupt is disabled\n1: interrupt is enabled\nFor reset mode: wdg_rst_en =1,  wdg_irq_en=0.\nFor interrupt mode: wdg_rst_en  =0, wdg_irq_en=1.\nFor combined mode: wdg_rst_en  =1, wdg_irq_en=1. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>wdg_run</spirit:name>
            <spirit:description> Watchdog counter open:\n0: counter stops.\n1: counter runs. </spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_CLR</spirit:name>
          <spirit:addressOffset>0xc</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x1</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_clr</spirit:name>
            <spirit:description> Watchdog interrupt clear\nWrite 1 to this bit to clear  interrupt\nRead this bit always get 0. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>write-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_RAW</spirit:name>
          <spirit:addressOffset>0x10</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x11</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_raw</spirit:name>
            <spirit:description> Watchdog interrupt raw status. Watch  dog reset cannot clear this raw status. Write wdg_int_clr can clear this raw  status. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>wdg_ld_busy</spirit:name>
            <spirit:description> Watchdog  load busy status\n0:  Watchdog is ready for new loading\n1: Last  loading is not completed\nSoftware  must not load new value when this bit is busy, that is, this bit should be  checked before any new loading.\nThis  bit is set after a new loading, and lasts two or three RTC clock cycles,  about 60us - 92us. </spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_INT_MASK</spirit:name>
          <spirit:addressOffset>0x14</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0x1</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_int_mask</spirit:name>
            <spirit:description> Watchdog interrupt masked  status </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>WDG_LOCK</spirit:name>
          <spirit:addressOffset>0xc00</spirit:addressOffset>
          <spirit:size>32</spirit:size>
          <spirit:reset>
            <spirit:value>0x0</spirit:value>
            <spirit:mask>0xffff</spirit:mask>
          </spirit:reset>
          <spirit:field>
            <spirit:name>wdg_lock</spirit:name>
            <spirit:description> Watchdog lock control\nWrite 32'h1ACCE551 to this register to unlock  watchdog.\nWrite other value to this  register to lock watchdog\nIf reading this register, bit-0  is lock status, and other bits are reserved.\nIf watchdog is locked, all  control registers cannot be written by software. </spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth>16</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
      </spirit:addressBlock>
