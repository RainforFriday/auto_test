<?xml version="1.0" encoding="utf-8"?>
<archive>
	<module name="trng" category="System">
		<reg name="trng_en">
			<bits name="sTrngEnQ" pos="2" access="rw" rst="0x0" >
				<comment> Block enable, high active. </comment>
			</bits>
			<bits name="sTrngIEQ" pos="3" access="rw" rst="0x0" >
				<comment> Interrupte enable, high active. </comment>
			</bits>
			<bits name="sTrngEEQ" pos="4" access="rw" rst="0x0" >
				<comment>  </comment>
			</bits>
		</reg>
		<reg name="trng_status">
			<bits name="sDRDYQ" pos="0" access="ro" rst="0x0" >
				<comment> Random data ready status. Read sDRQ(0x008) to clear status. </comment>
			</bits>
			<bits name="sSECSQ" pos="2" access="ro" rst="0x0" >
				<comment> Clock error current status. Write bit[6] 1'b0 to clear status. </comment>
			</bits>
			<bits name="sSEISQ" pos="6" access="ro" rst="0x0" >
				<comment> Seed error interrupt status. Write bit[6] 1'b0 to clear status. </comment>
			</bits>
		</reg>
		<reg name="trng_data">
			<bits name="sDRQ" pos="31:0" access="ro" rst="0x0" >
				<comment> Random 32-bit data. </comment>
			</bits>
		</reg>

		<hole size="4*8"/>

		<reg name="trng_div_dly">
			<bits name="sDivNumQ" pos="7:0" access="rw" rst="0x40" >
				<comment> Enable period </comment>
			</bits>
			<bits name="SDivHighQ" pos="15:8" access="rw" rst="0x10" >
				<comment> Enable high duration </comment>
			</bits>
			<bits name="sDlyNumQ" pos="23:16" access="rw" rst="0x8" >
				<comment> Delay number </comment>
			</bits>
		</reg>
		<reg name="trng_sel">
			<bits name="sTrngSel0Q" pos="7:0" access="rw" rst="0xf" >
				<comment> Trng Sel0 </comment>
			</bits>
			<bits name="sTrngSel1Q" pos="15:8" access="rw" rst="0xf0" >
				<comment> Trng Sel1 </comment>
			</bits>
			<bits name="sLfsrGen0Q" pos="23:16" access="rw" rst="0x0" >
				<comment> LFSR gen0 </comment>
			</bits>
			<bits name="sLfsrGen1Q" pos="31:24" access="rw" rst="0x0" >
				<comment> LFSR gen1 </comment>
			</bits>
		</reg>
	</module>
</archive>
