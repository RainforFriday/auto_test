                        <comment>SPI tx data control</comment>
                        <bits name="SPI_RX_DATA_LEN_H" pos="3:0" access="rw" rst="0x0" >
                                <comment> Indicates rx data length from slave, High 4 bits of spi rx data length</comment>
                        </bits>
                        <bits name="SPI_RX_DUMY_LEN" pos="9:4" access="rw" rst="0x0" >
                                <comment> Spi rx dummy clock length</comment>
                        </bits>
                        <bits name="CHNL_RX_LEN" pos="15:10" access="rw" rst="0x0" >
                                <comment> spi rx data len, used in spi mode 0</comment>
                        </bits>
