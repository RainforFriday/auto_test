<?xml version="1.0" encoding="utf-8"?>
<archive>
        <module name="DW_apb_spi" category="Periph">
                <reg name="SPI_TXD">
                        <comment>Write data to tx fifo
Read data from rx fifo</comment>
                        <bits name="SPI_TXD_RXD" pos="31:0" access="rw" rst="0x0" >
                                <comment> Write data to this address initiates a  character transmission through TX FIFO
  Read from this address retrieve data from  RX FIFO </comment>
                        </bits>
                </reg>
                <reg name="SPI_CLKD">
                        <comment>Clock divider bit 15 to 0.divider is 2(n+1)</comment>
                        <bits name="SPI_CLKD" pos="15:0" access="rw" rst="0x3" >
                        <comment>Specify the clock ratio between spi_sck and clk_spi
spi_sck = clk_spi/2(SPI_CLKD + 1)</comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL0">
                        <comment>SPI control register</comment>
                        <bits name="NG_RX" pos="0" access="rw" rst="0x0" >
                                <comment> "1" enable RX data shift in at clock neg-edge </comment>
                        </bits>
                        <bits name="NG_TX" pos="1" access="rw" rst="0x1" >
                                <comment> "1" enable TX data shift out at clock neg-edge </comment>
                        </bits>
                        <bits name="CHNL_LEN" pos="6:2" access="rw" rst="0x0" >
                                <comment> "0" 32 bits per word
 "1" 1 bits per word 
 "31" 31 bits per word </comment>
                        </bits>
                        <bits name="LSB" pos="7" access="rw" rst="0x0" >
                                <comment> "1": enable transmit data from LSB </comment>
                        </bits>
                        <bits name="SPI_CSN_PRE" pos="11:8" access="rw" rst="0xf" >
                                <comment> "1": cs is invalid 
 "0": cs is valid</comment>
                        </bits>
                        <bits name="Reserved" pos="12" access="rw" rst="0x0" >
                                <comment> Reserved </comment>
                        </bits>
                        <bits name="SCK_REV" pos="13" access="rw" rst="0x0" >
                                <comment> SCK inverse enable </comment>
                        </bits>
                        <bits name="SYNC_MD" pos="14" access="rw" rst="0x0" >
                                <comment> "1" : sync mode </comment>
                        </bits>
                        <bits name="SYNC_POL" pos="15" access="rw" rst="0x0" >
                                <comment> Sync polarity, positive or negative pulse for SPI or 3-wire mode, read command polarity </comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL1">
                        <comment>SPI control register</comment>
                        <bits name="S3W_POS" pos="4:0" access="rw" rst="0x0" >
                                <comment> 3-wire mode, w/r control position or the sync pulse position</comment>
                        </bits>
                        <bits name="S3W_MD" pos="5" access="rw" rst="0x0" >
                                <comment> "1" enable 3-wire mode</comment>
                        </bits>
                        <bits name="CS_H_MD" pos="6" access="rw" rst="0x0" >
                                <comment> 3-wire melody timing 1, csn high mode enable</comment>
                        </bits>
                        <bits name="S8_MD" pos="7" access="rw" rst="0x0" >
                                <comment> enable S8 mode</comment>
                        </bits>
                        <bits name="SYN_CSN_SEL" pos="11:8" access="rw" rst="0x0" >
                                <comment> S8 CD or SYNC signal maps to csn number
 0x1 selects csn0 as cd signal
 0x2 selects csn1 as cd signal
 in SPI_HS it must be 0x0</comment>
                        </bits>
                        <bits name="RTX_MD" pos="13:12" access="rw" rst="0x0" >
                                <comment> "0x00":idle mode
 "0x01":receive mode
 "0x10":transmit mode
 "0x11":transmit and receive</comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL2">
                        <comment>SPI control register</comment>
                        <bits name="S3W_RD_START" pos="4:0" access="rw" rst="0x0" >
                                <comment> Read date start bit, used for 3-wire mode and 3-wire 9bit RW mode</comment>
                        </bits>
                        <bits name="IS_SLVD" pos="5" access="rw" rst="0x0" >
                                <comment> "1" slave,only support microplus mode
"0" master</comment>
                        </bits>
                        <bits name="DMA_EN" pos="6" access="rw" rst="0x0" >
                                <comment> "1" : enable DMA </comment>
                        </bits>
                        <bits name="RX_ONLY_HLD" pos="7" access="rw" rst="0x0" >
                                <comment> "0" : working on only receive mode, when rxf_realfull is high, SPI will be held until rxf realfull is low </comment>
                        </bits>
                        <bits name="RX_DMA_SEL" pos="8" access="rw" rst="0x0" >
                                <comment> "0" : rx_dma_req keep high until receiving the rx_dma_ack
"1" : rx_dma_req is high when rx full is high</comment>
                        </bits>
                        <bits name="TX_DMA_SEL" pos="9" access="rw" rst="0x0" >
                                <comment> "0" : tx_dma_req keep high until receiving the tx_dma_ack
"1" : tx_dma_req is high when tx full is high</comment>
                        </bits>
                        <bits name="DMA_REQ_SEL" pos="10" access="rw" rst="0x0" >
                                <comment> "1" enable 3-wire mode</comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL3">
                        <comment>SPI control register</comment>
                        <bits name="RXF_FULL_THLD" pos="4:0" access="rw" rst="0x10" >
                                <comment> Receive data empty threshold </comment>
                        </bits>
                        <bits name="RXF_EMPTY_THLD" pos="12:8" access="rw" rst="0x10" >
                                <comment> Receive data full threshold </comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL4">
                        <comment>SPI control register</comment>
                        <bits name="BLOCK_NUM" pos="8:0" access="rw" rst="0x0" >
                                <comment> Number of data words ready to receive in "receive only" mode.
Only used for master mode</comment>
                        </bits>
                        <bits name="IS_RX_ONLY" pos="9" access="rw" rst="0x0" >
                                <comment> "1":receive data only.The bits should be written at last.
Only used for master mode</comment>
                        </bits>
                        <bits name="SYNC_HALF" pos="10" access="rw" rst="0x0" >
                                <comment> Sync half,sync width is half spi_sck cycle </comment>
                        </bits>
                        <bits name="SYNC_CLKMASK" pos="11" access="rw" rst="0x0" >
                                <comment> "1" Mask out the first clock pulse in SPI mode </comment>
                        </bits>
                        <bits name="PHS_DLY" pos="13:12" access="rw" rst="0x0" >
                                <comment> Phase delay. Relate to fast mode
 When in normal mode,this bit is not used. Only used for slave mode </comment>
                        </bits>
                        <bits name="IS_FST" pos="14" access="rw" rst="0x0" >
                                <comment> "0": normal mode
"1": fast mode </comment>
                        </bits>
                        <bits name="RX_ONLY_DO" pos="15" access="rw" rst="0x0" >
                                <comment> "0": SPI send all 0 to slave
"1": SPI send all 1 to slave </comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL5">
                        <comment>SPI control register</comment>
                        <bits name="ITVL_NUM" pos="15:0" access="rw" rst="0x0" >
                                <comment>For master, transmit data interval, programmabl n from 0 to 65535, delay is (4*n+3) clock cycle
For slave, max receive data interval. If slave has not sampled data,in the interval (4*n+3) spi_clk,slave will stop the receive process and send timeout interrupt </comment>
                        </bits>
                </reg>
                <reg name="SPI_INT_EN">
                        <comment>SPI interrupt enable register</comment>
                        <bits name="RXF_EMPTY_INT_EN" pos="1" access="rw" rst="0x0" >
                                <comment> Rx_fifo_empty interrupt enable </comment>
                        </bits>
                        <bits name="TXF_FUL_INT_EN" pos="2" access="rw" rst="0x0" >
                                <comment> Tx_fifo_full interrupt enable </comment>
                        </bits>
                        <bits name="RX_OVF_INT_EN" pos="4" access="rw" rst="0x0" >
                                <comment> Rx_overrun_reg interrupt enable </comment>
                        </bits>
                        <bits name="TIME_OUT_INT_EN" pos="5" access="rw" rst="0x0" >
                                <comment> Slave mode timeout interrupt enable </comment>
                        </bits>
                        <bits name="RXF_FULL_INT_EN" pos="6" access="rw" rst="0x0" >
                                <comment> Rx_fifo_full interrupt enable</comment>
                        </bits>
                        <bits name="TXF_EMPTY_INT_EN" pos="7" access="rw" rst="0x0" >
                                <comment> Tx_fifo_empty interrupt enable</comment>
                        </bits>
                        <bits name="TXF_END_INT_EN" pos="8" access="rw" rst="0x0" >
                                <comment> Tx end interrupt enable</comment>
                        </bits>
                        <bits name="RXF_END_INT_EN" pos="9" access="rw" rst="0x0" >
                                <comment> Rx end interrupt enable</comment>
                        </bits>
                </reg>
                <reg name="SPI_INT_CLR">
                        <comment>SPI interrupt clear register</comment>
                        <bits name="RXF_FULL_INT_CLR" pos="0" access="wo" rst="0x0" >
                                <comment> Write "1" clear Rx_fifo_full interrupt </comment>
                        </bits>
                        <bits name="RXF_EMPTY_INT_CLR" pos="1" access="wo" rst="0x0" >
                                <comment> Write "1" clear Rx_fifo_empty interrupt </comment>
                        </bits>
                        <bits name="TXF_FULL_INT_CLR" pos="2" access="wo" rst="0x0" >
                                <comment> Write "1" clear Tx_fifo_full interrupt </comment>
                        </bits>
                        <bits name="TXF_EMPTY_INT_CLR" pos="3" access="wo" rst="0x0" >
                                <comment> Write "1" clear Tx_fifo_empty interrupt </comment>
                        </bits>
                        <bits name="RX_OVF_INT_CLR" pos="4" access="wo" rst="0x0" >
                                <comment> Write "1" clear Rx_overrun_reg interrupt </comment>
                        </bits>
                        <bits name="TIME_OUT_INT_CLR" pos="5" access="wo" rst="0x0" >
                                <comment> Write "1" clear slave mode timeout interrupt </comment>
                        </bits>
                        <bits name="TXF_END_INT_CLR" pos="8" access="rw" rst="0x0" >
                                <comment> Tx data end interrupt clear</comment>
                        </bits>
                        <bits name="RXF_END_INT_CLR" pos="9" access="rw" rst="0x0" >
                                <comment> Rx data end interrupt clear</comment>
                        </bits>
                </reg>
                <reg name="SPI_INT_RAW_STS">
                        <comment>SPI interrupt raw status</comment>
                        <bits name="RX_FIFO_FULL_R" pos="0" access="ro" rst="0x0" >
                                <comment> Rx_fifo_full_r </comment>
                        </bits>
                        <bits name="RXF_EMPTY_RAW_STS" pos="1" access="ro" rst="0x1" >
                                <comment> Raw rx_fifo_empty interrupt </comment>
                        </bits>
                        <bits name="TXF_FULL_RAW_STS" pos="2" access="ro" rst="0x0" >
                                <comment> Raw Tx_fifo_full interrupt </comment>
                        </bits>
                        <bits name="TX_FIFO_EMPTY_W" pos="3" access="ro" rst="0x1" >
                                <comment> Raw txf_fifo_empty_empty interrupt </comment>
                        </bits>
                        <bits name="RX_OVF_RAW_STS" pos="4" access="ro" rst="0x0" >
                                <comment> Raw Rx_overrun_reg interrupt </comment>
                        </bits>
                        <bits name="TIME_OUT_RAW_STS" pos="5" access="ro" rst="0x0" >
                                <comment> Raw slave mode time out interrupt </comment>
                        </bits>
                        <bits name="RXF_FULL_RAW_STS" pos="6" access="ro" rst="0x0" >
                                <comment> Raw rxf_full interrupt. when the number of rx fifo data byte is larger than the the rx empty watermark value.Atuo clear </comment>
                        </bits>
                        <bits name="TXF_EMPTY_RAW_STS" pos="7" access="ro" rst="0x1" >
                                <comment> Raw txf_empty interrupt. when the number of tx fifo data byte is less than the the tx empty watermark value.Atuo clear</comment>
                        </bits>
                        <bits name="TX_END_IRQ" pos="8" access="ro" rst="0x0" >
                                <comment> Raw tx data end interrupt. bit is set when spi controller send TX_DATA_LEN data </comment>
                        </bits>
                        <bits name="RX_END_IRQ" pos="9" access="ro" rst="0x0" >
                                <comment> Raw rx data end interrupt. bit is set when spi controller receive RX_DATA_LEN data </comment>
                        </bits>
                </reg>
                <reg name="SPI_INT_MASK_STS">
                        <comment>SPI interrupt mask status</comment>
                        <bits name="RX_FIFO_EMPTY_MASK_STS" pos="1" access="ro" rst="0x0" >
                                <comment> Rx_fifo_empty  interrupt mask  status </comment>
                        </bits>
                        <bits name="TX_FIFO_FULL_MASK_STS" pos="2" access="ro" rst="0x0" >
                                <comment> Tx_fifo_full interrupt mask status </comment>
                        </bits>
                        <bits name="RX_OVF_MASK_STS" pos="4" access="ro" rst="0x0" >
                                <comment> Rx_overrun_reg interrupt mask status </comment>
                        </bits>
                        <bits name="TIME_OUT_MASK_STS" pos="5" access="ro" rst="0x0" >
                                <comment> Slave mode time out interrupt mask status </comment>
                        </bits>
                        <bits name="RXF_FULL_MASK_STS" pos="6" access="ro" rst="0x0" >
                                <comment> Rxf_full interrupt mask status. </comment>
                        </bits>
                        <bits name="TXF_EMPTY_MASK_STS" pos="7" access="ro" rst="0x0" >
                                <comment> Txf_empty interrupt mask status. </comment>
                        </bits>
                        <bits name="TXF_END_IRQ_MASK_STS" pos="8" access="ro" rst="0x0" >
                                <comment> Raw tx data end interrupt. bit is set when spi controller send TX_DATA_LEN data </comment>
                        </bits>
                        <bits name="RXF_END_IRQ_MASK_STS" pos="9" access="ro" rst="0x0" >
                                <comment> Raw rx data end interrupt. bit is set when spi controller receive RX_DATA_LEN data </comment>
                        </bits>
                </reg>
                <reg name="SPI_STS1">
                        <comment>SPI status register</comment>
                        <bits name="RXF_RD_ADDR" pos="4:0" access="ro" rst="0x0" >
                                <comment> RX FIFO read address </comment>
                        </bits>
                        <bits name="RXF_WR_ADDR" pos="12:8" access="ro" rst="0x0" >
                                <comment> RX FIFO write address </comment>
                        </bits>
                </reg>
                <reg name="SPI_STS2">
                        <comment>SPI status register</comment>
                        <bits name="RXF_FULL" pos="0" access="ro" rst="0x0" >
                                <comment> This bit is set when the number of RX FIFO data byte is larger than the RX full watermark value. Auto cleared when the condition disappears. </comment>
                        </bits>
                        <bits name="RXF_EMPTY" pos="1" access="ro" rst="0x1" >
                                <comment> This bit is set when the number of RX FIFO data byte is less than the RX empty interrupt watermark value. Auto cleared when the condition disappears. </comment>
                        </bits>
                        <bits name="TXF_FULL" pos="2" access="ro" rst="0x0" >
                                <comment> This bit is set when the number of TX FIFO data byte is larger than the TX full watermark value. Auto cleared when the condition disappears. </comment>
                        </bits>
                        <bits name="TXF_EMPTY" pos="3" access="ro" rst="0x1" >
                                <comment> This bit is set when the number of TX FIFO  data byte is less than the TX empty watermark value. Auto cleared when the condition disappears. </comment>
                        </bits>
                        <bits name="RXF_REALFULL" pos="4" access="ro" rst="0x0" >
                                <comment> RX FIFO is real full.(not relates to register RXF_FULL_THLD) </comment>
                        </bits>
                        <bits name="RXF_REALEMPTY" pos="5" access="ro" rst="0x1" >
                                <comment> RX FIFO is real empty. RX FIFO has no data </comment>
                        </bits>
                        <bits name="TXF_REALFULL" pos="6" access="ro" rst="0x0" >
                                <comment> TX FIFO is real full.(not relates to register TXF_FULL_THLD) </comment>
                        </bits>
                        <bits name="TXF_REALEMPTY" pos="7" access="ro" rst="0x1" >
                                <comment> TX FIFO is real empty. TX FIFO has no data </comment>
                        </bits>
                        <bits name="BUSY" pos="8" access="ro" rst="0x0" >
                                <comment> "1": busy, transmit process
"0": idle state </comment>
                        </bits>
                        <bits name="SPI_RXD" pos="9" access="ro" rst="0x0" >
                                <comment> Spi_rxd(monitor) </comment>
                        </bits>
                        <bits name="SPI_TXD" pos="10" access="ro" rst="0x0" >
                                <comment> Spi_txd(monitor) </comment>
                        </bits>
                        <bits name="SPI_SCK" pos="11" access="ro" rst="0x0" >
                                <comment> Spi_sck(monitor) </comment>
                        </bits>
                        <bits name="SPI_CS" pos="12" access="ro" rst="0x0" >
                                <comment> Spi_cs(monitor) </comment>
                        </bits>
                </reg>
                <reg name="DSP_WAIT">
                        <comment>Use for DSP control</comment>
                        <bits name="SPI_DSPWAIT" pos="3:0" access="rw" rst="0x1" >
                                <comment> This register is used for DSP control </comment>
                        </bits>
                        <bits name="RX_DATA_SWT" pos="5:4" access="rw" rst="0x0" >
                                <comment> Read data switch:
  0: rdata[31:0] = pdata[31:0]
  1: rdata = {pdata[7:0], pdata[15:8], pdata[23:16],  pdata[31:24]}
  2: rdata = {pdata[15:0],pdata[31:16]} </comment>
                        </bits>
                        <bits name="TX_DATA_SWT" pos="7:6" access="rw" rst="0x0" >
                                <comment> Write data switch:
  0: wdata[31:0] = pdata[31:0]
  1: wdata = {pdata[7:0], pdata[15:8], pdata[23:16],  pdata[31:24]}
  2: wdata = {pdata[15:0],pdata[31:16]} </comment>
                        </bits>
                </reg>
                <reg name="SPI_STS3">
                        <comment>SPI status register</comment>
                        <bits name="RX_CNT" pos="8:0" access="ro" rst="0x0" >
                                <comment> Working in only receive mode as master</comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL6">
                        <comment>SPI control register</comment>
                        <bits name="TXF_FULL_THLD" pos="4:0" access="rw" rst="0x8" >
                                <comment> TX FIFO data full threshold </comment>
                        </bits>
                        <bits name="TXF_EMPTY_THLD" pos="12:8" access="rw" rst="0x8" >
                                <comment> TX FIFO data empty threshold </comment>
                        </bits>
                </reg>
                <reg name="SPI_STS4">
                        <comment>SPI status register</comment>
                        <comment>SPI status register</comment>
                        <bits name="TXF_RD_ADDR" pos="4:0" access="ro" rst="0x0" >
                                <comment> TX FIFO read address </comment>
                        </bits>
                        <bits name="TXF_WR_ADDR" pos="12:8" access="ro" rst="0x0" >
                                <comment> TX FIFO write address </comment>
                        </bits>
                </reg>
                <reg name="SPI_FIFO_RST">
                        <comment>SPI tx/rx fifo reset bit</comment>
                        <bits name="SPI_FIFO_RST" pos="0" access="rw" rst="0x0" >
                                <comment> "1":reset all FIFOs </comment>
                        </bits>
                </reg>
                <reg name="SPI_CTL7">
                        <comment>SPI control register</comment>
                        <bits name="CSN_IE_CTL" pos="0" access="rw" rst="0x0" >
                                <comment> CSN IE output set
 0: not support csn input
 1: support csn input</comment>
                        </bits>
                        <bits name="CSN_I_SEL" pos="2:1" access="rw" rst="0x0" >
                                <comment> CSN select control:
0: CSN 0    1: CSN 1    2: CSN 2    3: CSN 3</comment>
                        </bits>
                        <bits name="SPI_MODE" pos="5:3" access="rw" rst="0x0" >
                                <comment> Used for master only
0: SPI_MODE disable
1: 3 wire 9 bit, cd bit, SDI/SDO share one IO
2: 3 wire 9 bit, cd bit, SDI,SDO
3: 4 wire 8 bit, cd pin, SDI/SDO
4: 4 wire 8 bit, cd pin, SDI,SDO</comment>
                        </bits>
                        <bits name="TX_CMD_SET" pos="6" access="rw" rst="0x0" >
                                <comment> 1: select fmark as the dma request
0:select software dma request </comment>
                        </bits>
                        <bits name="SPI_TX_HLD_EN" pos="7" access="rw" rst="0x0" >
                                <comment> 1: enable ahb2apb bridge write hold when tx fifo full
0: disable ahb2apb bridge write hold</comment>
                        </bits>
                        <bits name="SPI_RX_HLD_EN" pos="8" access="rw" rst="0x0" >
                                <comment> 1: enable ahb2apb bridge read hold when rx fifo empty
0: disable ahb2apb bridge write hold</comment>
                        </bits>
                        <bits name="SPI_SLV_CLK_SEl" pos="9" access="rw" rst="0x0" >
                                <comment> </comment>
                        </bits>
                        <bits name="SPI_SLV_EN" pos="10" access="rw" rst="0x0" >
                                <comment> Used when SPI slave in High speed mode
1:enable spi slave rtx
0:disable spi slave rtx
</comment>
                        </bits>
                        <bits name="SPI_SLV_SEL" pos="11" access="rw" rst="0x0" >
                                <comment> 1: SPI slave in low speed mode
0: SPI slave in low speed mode</comment>
                        </bits>
                        <bits name="RGB_888_EN" pos="12" access="rw" rst="0x0" >
                                <comment> </comment>
                        </bits>
                        <bits name="RGB_666_EN" pos="13" access="rw" rst="0x0" >
                                <comment> </comment>
                        </bits>
                        <bits name="RGB_565_EN" pos="14" access="rw" rst="0x0" >
                                <comment> </comment>
                        </bits>
                        <bits name="DATA_LINE2_EN" pos="15" access="rw" rst="0x0" >
                                <comment> </comment>
                        </bits>
                </reg>
